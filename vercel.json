{
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.9.0" },
    { "src": "dist/output.css", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/faq", "dest": "/faq.php" },
    { "src": "/contact", "dest": "/contact.php" },
    { "src": "/download", "dest": "/download.php" },
    { "src": "/privacy-policy", "dest": "/privacy-policy.php" },
    { "src": "/terms-and-conditions", "dest": "/terms-and-conditions.php" }
  ]
}
